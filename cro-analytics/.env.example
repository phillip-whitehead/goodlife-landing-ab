# Copy this file to .env and fill in your values
# The .env file is gitignored — never commit real credentials

# Path to GA4 service account JSON key file
GA4_KEY_FILE=/path/to/your-service-account-key.json

# GA4 property ID (found in Analytics Admin > Property Settings)
GA4_PROPERTY_ID=375125067

# HubSpot Private App access token (Settings > Integrations > Private Apps)
HUBSPOT_TOKEN=pat-na1-...your-token-here...
