# Good Life Bahamas — CRO Analytics Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Google Analytics 4 ────────────────────────────────────────────────────────
GA4_KEY_FILE=/Users/phillipwhitehead/Downloads/good-life-analytics-e63b31a4c3e7.json
GA4_PROPERTY_ID=375125067

# ── HubSpot ───────────────────────────────────────────────────────────────────
# Private App token from HubSpot → Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.read, crm.objects.deals.read
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Microsoft Clarity ─────────────────────────────────────────────────────────
# Project ID: in your Clarity dashboard URL → clarity.microsoft.com/projects/view/XXXXXX
CLARITY_PROJECT_ID=

# API Key: Clarity → Settings → API → Generate API key
CLARITY_API_KEY=

# What Clarity API gives you automatically each week:
#   ✅  Rage click rate %
#   ✅  Dead click rate %
#   ✅  Quick-back rate % (intent mismatch signal)
#   ✅  Average scroll depth %
#   ✅  Excessive scroll rate %
#   ✅  Average active time (seconds)
#   ✅  All broken down per landing page version
#   ❌  Heatmap images → review manually in Clarity dashboard (15 min/week)
#   ❌  Session recordings → watch top 3-5 manually each week
